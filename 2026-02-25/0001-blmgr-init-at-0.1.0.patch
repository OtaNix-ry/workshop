From 670a90dbc9d2230d44713da51121041a85d9d22c Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Luukas=20P=C3=B6rtfors?= <lajp@iki.fi>
Date: Wed, 25 Feb 2026 18:08:59 +0200
Subject: [PATCH 1/2] blmgr: init at 0.1.0

---
 pkgs/by-name/bl/blmgr/package.nix | 31 +++++++++++++++++++++++++++++++
 1 file changed, 31 insertions(+)
 create mode 100644 pkgs/by-name/bl/blmgr/package.nix

diff --git a/pkgs/by-name/bl/blmgr/package.nix b/pkgs/by-name/bl/blmgr/package.nix
new file mode 100644
index 000000000000..4d177c449380
--- /dev/null
+++ b/pkgs/by-name/bl/blmgr/package.nix
@@ -0,0 +1,31 @@
+{
+  # pkgs.blmgr.override { amdgpu = true; }
+  clangStdenv,
+  fetchFromGitHub,
+  amdgpu ? true,
+  lib,
+}:
+clangStdenv.mkDerivation (old: {
+  pname = "blmgr";
+  version = "0.1.0";
+
+  patches = lib.optionals amdgpu [
+    "${old.src}/blmgr-amdgpu.patch"
+  ];
+
+  src = fetchFromGitHub {
+    owner = "lajp";
+    repo = "blmgr";
+    rev = "c9a0a3f6be5810e84625c76275b39b89ec589739";
+    hash = "sha256-T66C03iP+xnnrq2JSuLwIEN8tQ94oOaLvHzeuulzxyQ=";
+  };
+
+  installPhase = ''
+    runHook preInstall
+
+    mkdir -p $out/bin
+    make install INSTALL_PATH=$out/bin
+
+    runHook postInstall
+  '';
+})
-- 
